<Window x:Class="KinectReframe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kinect Reframe"
        Width="1450"
        Height="930"
        MinWidth="1080"
        MinHeight="760"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid x:Name="RootVisual" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="KINECT REFRAME" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="Xbox 360 Kinect tracking, depth rendering and camera lab"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ConnectionIndicator" Width="10" Height="10" Fill="#D85858" Margin="0,0,8,0" />
                    <TextBlock x:Name="ConnectionText" Text="Waiting for sensor" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="MainContentGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition x:Name="RightPanelSpacerColumn" Width="16" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="2*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="CameraViewport"
                    Grid.Column="0"
                    Background="#050607"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    ClipToBounds="True">
                <Grid>
                    <Viewbox Stretch="Uniform">
                        <Grid x:Name="CameraSurface" Width="640" Height="480" RenderTransformOrigin="0.5,0.5">
                            <Image x:Name="ColorImage" Width="640" Height="480" Stretch="Fill" />
                            <Image x:Name="DepthHeatmapImage"
                                   Width="640"
                                   Height="480"
                                   Stretch="Fill"
                                   Opacity="0.72"
                                   Visibility="Collapsed"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <Image x:Name="MotionHeatmapImage"
                                   Width="640"
                                   Height="480"
                                   Stretch="Fill"
                                   Opacity="0.82"
                                   Visibility="Collapsed"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <Canvas x:Name="SkeletonCanvas"
                                    Width="640"
                                    Height="480"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False" />
                            <Canvas x:Name="GridOverlayCanvas"
                                    Width="640"
                                    Height="480"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False"
                                    Opacity="0.55">
                                <Line X1="213" Y1="0" X2="213" Y2="480" Stroke="#D9FFFFFF" StrokeThickness="1" />
                                <Line X1="427" Y1="0" X2="427" Y2="480" Stroke="#D9FFFFFF" StrokeThickness="1" />
                                <Line X1="0" Y1="160" X2="640" Y2="160" Stroke="#D9FFFFFF" StrokeThickness="1" />
                                <Line X1="0" Y1="320" X2="640" Y2="320" Stroke="#D9FFFFFF" StrokeThickness="1" />
                                <Line X1="300" Y1="240" X2="340" Y2="240" Stroke="#D9FFFFFF" StrokeThickness="1" />
                                <Line X1="320" Y1="220" X2="320" Y2="260" Stroke="#D9FFFFFF" StrokeThickness="1" />
                            </Canvas>
                        </Grid>
                    </Viewbox>

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#B0101318"
                            Padding="10,6"
                            Margin="10">
                        <TextBlock x:Name="CameraModeText" Text="RGB CAMERA" FontSize="12" FontWeight="SemiBold" />
                    </Border>

                    <Border x:Name="FreezeBadge"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="#D9D85858"
                            Padding="12,6"
                            Margin="10"
                            Visibility="Collapsed">
                        <TextBlock Text="FRAME FROZEN" FontWeight="Bold" />
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="RightPanelBorder"
                    Grid.Column="2"
                    Background="#030A0B"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    ClipToBounds="True">
                <TabControl Background="#030A0B" BorderThickness="0">
                    <TabItem Header="DEPTH HOLOGRAM">
                        <Grid Background="#030A0B">
                            <Image x:Name="BodyImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#B0101318"
                                    Padding="10,6"
                                    Margin="10">
                                <TextBlock Text="PLAYER-INDEXED DEPTH" FontSize="12" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock x:Name="NoBodyText"
                                       Text="Move into view"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="20" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="3D POINT CLOUD">
                        <Grid x:Name="PointCloudViewport"
                              Background="#020607"
                              Cursor="SizeAll"
                              MouseLeftButtonDown="PointCloudViewport_MouseLeftButtonDown"
                              MouseLeftButtonUp="PointCloudViewport_MouseLeftButtonUp"
                              MouseMove="PointCloudViewport_MouseMove"
                              MouseWheel="PointCloudViewport_MouseWheel">
                            <Image x:Name="PointCloudImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#B0101318"
                                    Padding="10,6"
                                    Margin="10">
                                <TextBlock Text="LIVE CAMERA-SPACE POINT CLOUD" FontSize="12" FontWeight="SemiBold" />
                            </Border>
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Background="#B0101318"
                                    Padding="10,7"
                                    Margin="10">
                                <StackPanel>
                                    <TextBlock Text="Drag to orbit • wheel to zoom" FontSize="11" />
                                    <TextBlock x:Name="PointCloudViewText"
                                               Text="Yaw 0°  Pitch 0°  Zoom 1.00x"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11"
                                               Margin="0,3,0,0" />
                                    <TextBlock x:Name="PointCloudCountText"
                                               Text="0 rendered points"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="11" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="4"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <ToggleButton x:Name="SkeletonToggle"
                                  Content="Skeleton"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="False"
                                  Checked="VisualToggle_Changed"
                                  Unchecked="VisualToggle_Changed" />
                    <ToggleButton x:Name="RawSkeletonToggle"
                                  Content="Raw skeleton"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="False"
                                  IsEnabled="False" />
                    <ToggleButton x:Name="MotionHeatToggle"
                                  Content="Motion heat"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="False"
                                  Checked="HeatmapToggle_Changed"
                                  Unchecked="HeatmapToggle_Changed" />
                    <ToggleButton x:Name="DepthHeatToggle"
                                  Content="Depth heat"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="False"
                                  Checked="HeatmapToggle_Changed"
                                  Unchecked="HeatmapToggle_Changed" />
                    <ToggleButton x:Name="MirrorToggle"
                                  Content="Mirror"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="True"
                                  Checked="VisualToggle_Changed"
                                  Unchecked="VisualToggle_Changed" />
                    <ToggleButton x:Name="FreezeToggle"
                                  Content="Freeze"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="False"
                                  Checked="VisualToggle_Changed"
                                  Unchecked="VisualToggle_Changed" />
                    <ToggleButton x:Name="GridToggle"
                                  Content="Grid"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="False"
                                  Checked="VisualToggle_Changed"
                                  Unchecked="VisualToggle_Changed" />
                    <ToggleButton x:Name="FocusCameraToggle"
                                  Content="Focus camera"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="False"
                                  Checked="VisualToggle_Changed"
                                  Unchecked="VisualToggle_Changed" />
                    <ToggleButton x:Name="BodyOnlyToggle"
                                  Content="Body-only renders"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="True" />
                    <ToggleButton x:Name="SeatedModeToggle"
                                  Content="Seated tracking"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="True"
                                  Checked="SeatedModeToggle_Changed"
                                  Unchecked="SeatedModeToggle_Changed" />
                </WrapPanel>

                <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                    <TextBlock Text="Brightness" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Slider x:Name="BrightnessSlider"
                            Width="105"
                            Minimum="-80"
                            Maximum="80"
                            Value="0"
                            ValueChanged="CameraAdjustmentSlider_Changed" />
                    <TextBlock x:Name="BrightnessValueText" Text="0" Width="34" VerticalAlignment="Center" />

                    <TextBlock Text="Contrast" VerticalAlignment="Center" Margin="12,0,8,0" />
                    <Slider x:Name="ContrastSlider"
                            Width="105"
                            Minimum="0.6"
                            Maximum="1.6"
                            Value="1"
                            ValueChanged="CameraAdjustmentSlider_Changed" />
                    <TextBlock x:Name="ContrastValueText" Text="1.00" Width="42" VerticalAlignment="Center" />

                    <TextBlock Text="Smoothing" VerticalAlignment="Center" Margin="12,0,8,0" />
                    <Slider x:Name="SmoothingSlider"
                            Width="105"
                            Minimum="0.08"
                            Maximum="1"
                            Value="0.35"
                            ValueChanged="SmoothingSlider_ValueChanged" />
                    <TextBlock x:Name="SmoothingValueText" Text="0.35" Width="42" VerticalAlignment="Center" />

                    <TextBlock Text="Motion threshold" VerticalAlignment="Center" Margin="12,0,8,0" />
                    <Slider x:Name="MotionThresholdSlider"
                            Width="105"
                            Minimum="10"
                            Maximum="180"
                            Value="35"
                            ValueChanged="HeatmapSlider_Changed" />
                    <TextBlock x:Name="MotionThresholdValueText" Text="35 mm" Width="55" VerticalAlignment="Center" />

                    <TextBlock Text="Trail" VerticalAlignment="Center" Margin="12,0,8,0" />
                    <Slider x:Name="MotionPersistenceSlider"
                            Width="105"
                            Minimum="0.75"
                            Maximum="0.995"
                            Value="0.94"
                            ValueChanged="HeatmapSlider_Changed" />
                    <TextBlock x:Name="MotionPersistenceValueText" Text="0.940" Width="48" VerticalAlignment="Center" />
                </WrapPanel>

                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                    <TextBlock Text="3D detail" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Slider x:Name="PointCloudDetailSlider"
                            Width="105"
                            Minimum="1"
                            Maximum="4"
                            Value="4"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="RenderSettingSlider_Changed" />
                    <TextBlock x:Name="PointCloudDetailValueText" Text="4" Width="28" VerticalAlignment="Center" />

                    <TextBlock Text="Point size" VerticalAlignment="Center" Margin="12,0,8,0" />
                    <Slider x:Name="PointCloudPointSizeSlider"
                            Width="105"
                            Minimum="1"
                            Maximum="4"
                            Value="2"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="RenderSettingSlider_Changed" />
                    <TextBlock x:Name="PointCloudPointSizeValueText" Text="2" Width="28" VerticalAlignment="Center" />

                    <ToggleButton x:Name="PointCloudShadingToggle"
                                  Content="3D shading"
                                  ToolTip="Uses neighbouring depth points to reveal surface shape"
                                  Style="{StaticResource PillToggleStyle}"
                                  IsChecked="True" />

                    <TextBlock Text="Output scale" VerticalAlignment="Center" Margin="12,0,8,0" />
                    <Slider x:Name="OutputScaleSlider"
                            Width="130"
                            Minimum="0.5"
                            Maximum="3"
                            Value="1"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            ValueChanged="OutputScaleSlider_Changed" />
                    <TextBlock x:Name="OutputResolutionText"
                               Text="640 × 480 (1.0x)"
                               Width="130"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                </WrapPanel>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <WrapPanel>
                        <Button x:Name="RecordButton" Content="Record tracking data" Click="RecordButton_Click" />
                        <Button Content="Save app snapshot" Click="SnapshotButton_Click" />
                        <Button Content="Save camera output" Click="CameraSnapshotButton_Click" />
                        <Button Content="Export PLY" Click="ExportPointCloudButton_Click" />
                        <Button Content="Clear heat" Click="ClearHeatmapButton_Click" Background="#DCE6EA" />
                        <Button Content="Reset camera" Click="ResetCameraButton_Click" Background="#DCE6EA" />
                        <Button Content="Reset tracking" Click="ResetFiltersButton_Click" Background="#DCE6EA" />
                        <Button Content="Reset 3D" Click="ResetPointCloudViewButton_Click" Background="#DCE6EA" />
                    </WrapPanel>

                    <TextBlock Grid.Column="1"
                               x:Name="TrackingStatusText"
                               Text="No skeleton tracked"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="10,0" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="FPS " Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock x:Name="FpsText" Text="0" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
